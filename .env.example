# Copy to .env and fill in
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# LOGIC_MODEL=claude-sonnet-4-6
# LOGIC_DRY_RUN=1        # print AppleScript instead of executing (for testing)
# LOGIC_APP_NAME=Logic Pro
# LOGIC_AUTOSEND_MS=1200 # input-silence window before auto-send

# Local model backend (Ollama / LM Studio — any OpenAI-compatible server)
# LOGIC_BACKEND=ollama               # default: claude
# LOGIC_LOCAL_URL=http://localhost:11434/v1
# LOGIC_LOCAL_MODEL=gemma4:26b       # drop to gemma4:e4b when RAM is tight
# LOGIC_LOCAL_API_KEY=ollama
